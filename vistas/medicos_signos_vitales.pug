doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Registros de Signos Vitales
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css", rel="stylesheet")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css")
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")
  
  body.bg-light

    .navbar.navbar-expand-sm.bg-info.navbar-dark.p-3.mb-4
       .container-fluid
           .navbar-brand
               h4.display-6.px-4.text-white Sistema Hospitalario
           .d-flex.ms-auto.align-items-center
               if usuario
                   span.text-white.me-2= usuario.nombre_usuario
               a(href="/logout", title="Cerrar sesión")
                   i.fas.fa-sign-out-alt.text-white



    .container
        .card.shadow-sm.border-0
            .card-header.bg-white
                h5.text-info Registro de signos vitales
            .card-body
                if signos && signos.length > 0
                    .table-responsive
                        table.table.table-hover.align-middle
                            thead.table-danger
                                tr
                                    th Fecha y Hora
                                    th Presión (mmHg)
                                    th FC (lpm)
                                    th FR (rpm)
                                    th Temp (°C)
                                    th Observaciones
                            tbody
                                each signo in signos
                                    tr
                                        td 
                                            strong= new Date(signo.fecha_hora).toLocaleString('es-AR', { dateStyle: 'short', timeStyle: 'short' })
                                        td= signo.presion_arterial || '-'
                                        td= signo.frecuencia_cardiaca || '-'
                                        td= signo.frecuencia_respiratoria || '-'
                                        td= signo.temperatura || '-'
                                        td.small.text-muted= signo.observaciones || '-'
                else
                    tr
                        td.text-center.text-muted.py-3(colspan="6") 
                            i.fas.fa-info-circle.me-2
                            | No hay registros previos de signos vitales para esta internación.

        .row.justify-content-center.mb-5.mt-4
            .col-md-3.mb-4
                a(href=`/medicos/historial/${internacion.ID}`, class="text-decoration-none h-100")
                    .card.h-100.shadow.text-center.border-0.hover-shadow
                        i.fa-solid.fa-file-alt.fa-4x.text-info.mt-4
                        .card-body
                            h5.card-title.text-info Historia Clínica

            .col-md-3.mb-4
                a(href=`/medicos/medicacion-administrada/${internacion.ID}`, class="text-decoration-none h-100")
                    .card.h-100.shadow.text-center.border-0
                        i.fa-solid.fa-syringe.fa-4x.text-success.mt-4
                        .card-body
                            h5.card-title.text-success Registros de Medicación
            .col-md-3.mb-4
                a(href=`/medicos/buscar?numeroDNI=${internacion.paciente.DNI}`, class="text-decoration-none h-100")
                    .card.h-100.shadow.text-center.border-0
                        i.fa-solid.fa-file-medical.fa-4x.text-warning.mt-4
                        .card-body
                            h5.card-title.text-warning Evoluciones y Estudios
            .col-md-3.mb-4
                a(href="#", class="text-decoration-none h-100", data-bs-toggle="modal", data-bs-target="#modalConfirmarAlta")
                    .card.h-100.shadow.text-center.border-0.bg-light
                        i.fa-solid.fa-house-medical-circle-check.fa-4x.text-secondary.mt-4
                        .card-body
                            h5.card-title.text-secondary Dar de Alta

include modal_alta.pug
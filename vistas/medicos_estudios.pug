doctype html
html(lang="es")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Resultados de Estudios
        link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css", rel="stylesheet")
        link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css")

    body.bg-light
        .navbar.navbar-expand-sm.bg-warning.navbar-dark.p-3.mb-4
            .container-fluid
                .navbar-brand
                    h4.display-6.px-4.text-dark <i class="fas fa-x-ray me-2"></i> Resultados de Estudios
                .d-flex.ms-auto.align-items-center
                    if usuario
                        span.text-dark.me-2= usuario.nombre_usuario

        .container
            .d-flex.justify-content-between.align-items-center.mb-3
                h5.text-secondary Paciente: <strong class="text-dark">#{internacion.paciente.Nombre} #{internacion.paciente.Apellido}</strong>
                a.btn.btn-outline-secondary(href=`/medicos/buscar?numeroDNI=${internacion.paciente.DNI}`) 
                    i.fas.fa-arrow-left.me-1 
                    | Volver a la Consulta

            .card.shadow-sm
                .card-body
                    if estudios && estudios.length > 0
                        .table-responsive
                            table.table.table-striped.table-hover.align-middle
                                thead.table-warning
                                    tr
                                        th Tipo de Estudio
                                        th Detalle Solicitado
                                        th Estado / Informe
                                tbody
                                    each est in estudios
                                        tr
                                            td <strong>#{est.tipo_estudio}</strong>
                                            td= est.descripcion
                                            td 
                                                if est.resultado
                                                    span.badge.bg-success.mb-1 Realizado
                                                    p.small.text-dark.mb-0 <strong>Informe:</strong> #{est.resultado}
                                                else
                                                    span.badge.bg-danger Pendiente de informe
                    else
                        .alert.alert-info.text-center.mb-0 No se han solicitado estudios diagnósticos en esta internación.
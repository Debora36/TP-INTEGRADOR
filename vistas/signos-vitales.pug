doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title evaluacion inicial
        link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet")
        link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css")
        script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")
    body.bg-light
        .navbar.navbar-expand-sm.bg-info.navbar-dark.p-3.mb-4
            .container-fluid
                .navbar-brand
                    h4.display-6.px-4.text-white Sistema Hospitalario
                .d-flex.ms-auto.align-items-center
                    if usuario
                        span.text-white.me-2= usuario.nombre_usuario
                    a(href="/logout" title="Cerrar sesión")
                        i.fas.fa-sign-out-alt.text-white

        .container
            //- MENSAJES
            if mensaje
                .alert.alert-warning.text-center #{mensaje}
            if errores
                .alert.alert-danger(role='alert')= errores


        block contenido
            .container.mt-4                       
                //TARJETA DEL PACIENTE
                .card.border-0.shadow-sm.mb-4
                    .card-body.bg-white
                        .row.align-items-center
                            .col-md-4.text-center
                                h3.text-primary #{paciente.Nombre} #{paciente.Apellido}
                                text-muted DNI: 
                                strong #{paciente.DNI}

                            .col-md-8
                                .row.text-center.mt-2
                                    .col-md-3
                                        p.mb-1.text-muted Fecha Nac.
                                        strong= paciente.FechaNacimiento ? new Date(paciente.FechaNacimiento).toLocaleDateString('es-AR') : 'N/A'
                                    .col-md-3
                                        p.mb-1.text-muted Obra Social
                                        strong #{paciente.obra_social ? paciente.obra_social.nombre : 'N/A'}
                                    .col-md-3
                                        p.mb-1.text-muted Plan
                                        strong #{paciente.plan_detalle ? paciente.plan_detalle.nombre_plan : 'N/A'}
                                    .col-md-3
                                        p.mb-1.text-muted N° Afiliado
                                        strong #{paciente.numero_afiliado || 'N/A'}

                
                //FORMULARIO PRINCIPAL
                form#formGuardarSignos(action="/enfermeria/guardarSignos" method="POST")
                    input(type="hidden" name="id_signos" value=id_signos || '')
                    input(type="hidden" name="internacion_id" value=internacion.ID)
                    //TARJETA DE SIGNOS VITALES
                    .row.justify-content-center
                        .col-md-12
                            .card.shadow-sm.mb-4
                                .card-header.bg-danger.text-white 
                                    | Parámetros Clínicos Actuales
                                .card-body
                                    .row
                                        //primer columna
                                        .col-md-6
                                            .mb-3
                                                label.form-label Presión Arterial (mmHg)
                                                input.form-control(type="text" name="presion_arterial" value=presion_arterial || '' placeholder="Ej: 120/80" required)
                                            .mb-3
                                                label.form-label Frecuencia Cardíaca (lpm)
                                                input.form-control(type="number" name="frecuencia_cardiaca" step="1" min="0" value=frecuencia_cardiaca || '' placeholder="Ej: 80" required)
                                            .mb-3
                                                label.form-label Frecuencia Respiratoria (rpm)
                                                input.form-control(type="number" name="frecuencia_respiratoria" step="1" min="0" value=frecuencia_respiratoria || '' placeholder="Ej: 16")
                                        
                                        //segunda columnaa
                                        .col-md-6
                                            .mb-3
                                                label.form-label Temperatura (°C)
                                                input.form-control(type="number" name="temperatura" step="0.1" min="0" value=temperatura || '' placeholder="Ej: 36.5" required)
                                            .mb-3
                                                label.form-label Color de Piel
                                                select.form-select(name="color_piel")
                                                    option(value="Normal" selected=(color_piel === 'Normal' || !id)) Normal
                                                    option(value="Rosado" selected=(color_piel === 'Rosado')) Rosado
                                                    option(value="Pálido" selected=(color_piel === 'Pálido')) Pálido
                                                    option(value="Cianótico" selected=(color_piel === 'Cianótico')) Cianótico
                                                    option(value="Ictérico" selected=(color_piel === 'Ictérico')) Ictérico
                                            .mb-3
                                                label.form-label Respuesta a Estímulos
                                                select.form-select(name="respuesta_estimulos")
                                                    option(value="5" selected=(respuesta_estimulos == 5 || !id)) 5 - Alerta y orientado
                                                    option(value="4" selected=(respuesta_estimulos == 4)) 4 - Confuso / letárgico
                                                    option(value="3" selected=(respuesta_estimulos == 3)) 3 - Responde a la voz
                                                    option(value="2" selected=(respuesta_estimulos == 2)) 2 - Responde al dolor
                                                    option(value="1" selected=(respuesta_estimulos == 1)) 1 - Sin respuesta



                //TABLA DE HISTORIAL
                .row.justify-content-center.mb-5
                    .col-md-12
                        .card.shadow-sm
                            .card-header.bg-white
                                h5.text-info Historial de Evolución
                            .card-body
                                .table-responsive
                                    table.table.table-sm.table-hover.mt-3
                                        thead.table-light
                                            tr
                                                th Fecha y Hora
                                                th Presión (mmHg)
                                                th FC (lpm)
                                                th FR (rpm)
                                                th Temp (°C)
                                                th Observaciones
                                                th Acción
                                        tbody#tablaSignos
                                            if historialSignos && historialSignos.length > 0
                                                each signo, index in historialSignos
                                                    tr(id=`fila-signo-${index}`)
                                                        td
                                                            strong= new Date(signo.fecha_hora).toLocaleString('es-AR', { dateStyle: 'short', timeStyle: 'short' })
                                                        td= signo.presion_arterial || '-'
                                                        td= signo.frecuencia_cardiaca || '-'
                                                        td= signo.frecuencia_respiratoria || '-'
                                                        td= signo.temperatura || '-'
                                                        td.small.text-muted= signo.observaciones || '-'
                                                        td.d-flex.gap-2
                                                            a.btn.btn-warning.btn-sm(href=`/enfermeria/signos/${internacion.ID}?edit=${signo.id}`)
                                                                i.fas.fa-pencil-alt
                                                            form(action=`/enfermeria/signos/eliminar/${signo.id}` method="POST" onsubmit="return confirm('¿Estás seguro de eliminar este registro de signos vitales?')")
                                                                //- Pasamos el id de internación para saber a dónde redirigir después
                                                                input(type="hidden" name="internacion_id" value=internacion.ID)
                                                                button.btn.btn-danger.btn-sm(type="submit") 
                                                                    i.fas.fa-trash
                                                            
                                            else
                                                tr
                                                    td.text-center.text-muted.py-3(colspan="6") 
                                                        i.fas.fa-info-circle.me-2
                                                        | No hay registros previos de signos vitales para esta internación.

                    
                .card-mt-3.mb-5
                    .card-body.d-flex.justify-content-between.align-items-center
                        a.btn.btn-outline-secondary(href="/enfermeria") 
                            <i class="fas fa-arrow-left"></i>
                        button.btn.btn-success.btn-lg(type="submit" form="formGuardarSignos")
                            | #{id_signos ? 'Actualizar' : 'Guardar'}


                //BOTONES DE ACCIÓN

                hr.my-4

                .row.justify-content-center
                    .col-md-4.mb-4
                        a(href=`/enfermeria/historia/${internacion.ID}`, class="text-decoration-none h-100")
                            .card.h-100.shadow.text-center.border-0.hover-shadow
                                i.fa-solid.fa-file-alt.fa-4x.text-info.mt-4
                                .card-body
                                    h5.card-title.text-info Historia Clínica
                                    p.card-text.small Ver antecedentes y datos pasados.

                    .col-md-4.mb-4
                        a(href=`/enfermeria/evaluacion/${internacion.ID}`, class="text-decoration-none h-100")
                            .card.h-100.shadow.text-center.border-0
                                i.fa-solid.fa-clipboard-list.fa-4x.text-warning.mt-4
                                .card-body
                                    h5.card-title.text-warning Evaluación Inicial
                                    p.card-text.small Cargar alergias, motivo de ingreso y triage.
                    .col-md-4.mb-4
                        a(href=`/enfermeria/administrar/${internacion.ID}`, class="text-decoration-none h-100")
                            .card.h-100.shadow.text-center.border-0
                                i.fa-solid.fa-syringe.fa-4x.text-success.mt-4
                                .card-body
                                    h5.card-title.text-success Administrar Medicación
                                    p.card-text.small Registrar administración de medicamentos.
doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title evaluacion inicial
        link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet")
        link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css")
        script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")
    body.bg-light
        .navbar.navbar-expand-sm.bg-info.navbar-dark.p-3.mb-4
            .container-fluid
                .navbar-brand
                    h4.display-6.px-4.text-white Sistema Hospitalario
                .d-flex.ms-auto.align-items-center
                    if usuario
                        span.text-white.me-2= usuario.nombre_usuario
                    a(href="/logout" title="Cerrar sesión")
                        i.fas.fa-sign-out-alt.text-white

        .container
            //- MENSAJES
            if mensaje
                .alert.alert-success(role='alert')= mensaje
            if errores
                .alert.alert-danger(role='alert')= errores


        block contenido
            .container.mt-4                       
                //- TARJETA DEL PACIENTE
                .card.border-0.shadow-sm.mb-4
                    .card-body.bg-white
                        .row.align-items-center
                            .col-md-4.text-center
                                h3.text-primary #{paciente.Nombre} #{paciente.Apellido}
                                text-muted DNI: 
                                strong #{paciente.DNI}

                            //Datos
                            .col-md-8
                                .row.text-center.mt-2
                                    .col-md-3
                                        p.mb-1.text-muted Fecha Nac.
  
                                        strong= paciente.FechaNacimiento ? new Date(paciente.FechaNacimiento).toLocaleDateString('es-AR') : 'N/A'
                                    .col-md-3
                                        p.mb-1.text-muted Obra Social
                                        strong #{paciente.obra_social ? paciente.obra_social.nombre : 'N/A'}
                                    .col-md-3
                                        p.mb-1.text-muted Plan
                                        strong #{paciente.plan_detalle ? paciente.plan_detalle.nombre_plan : 'N/A'}
                                    .col-md-3
                                        p.mb-1.text-muted N° Afiliado
                                        strong #{paciente.numero_afiliado || 'N/A'}

                //FORMULARIO PRINCIPAL
                //Uso una sola ruta para guardar y actualizar
                form(action="/enfermeria/guardarEvaluacion" method="POST")
                    
                    input(type="hidden" name="id_internacion" value=internacion.ID)
                    input(type="hidden" name="id_paciente" value=paciente.id)

                    //Si estoy editando, mando el ID. Si no, no se renderiza este input.
                    if evaluacion.ID
                        input(type="hidden" name="id_evaluacion" value=evaluacion.ID)
                    .row
                        .col-md-6
                            .card.shadow-sm.mb-3
                                .card-header.bg-info.text-white 
                                    | Datos Clínicos
                                .card-body
                                    .mb-3
                                        label.form-label Motivo de Ingreso
                                        input.form-control(type="text" name="motivoIngreso" value=evaluacion.Motivo_Principal || '' required)
                                    .mb-3
                                        label.form-label Sintomatología
                                        textarea.form-control(name="Sintomas" rows="3")= evaluacion.Sintomas_Desc || '' 
                                    .mb-3
                                        label.form-label Prioridad Clínica
                                        select.form-select(name="Prioridad")
                                            option(value="Baja" selected=(evaluacion.Prioridad === 'Baja')) Baja
                                            option(value="Media" selected=(!evaluacion.ID || evaluacion.Prioridad === 'Media')) Media
                                            option(value="Alta" selected=(evaluacion.Prioridad === 'Alta')) Alta
                                            option(value="Emergencia" selected=(evaluacion.Prioridad === 'Emergencia')) Emergencia
                                    .mb-3
                                        label.form-label Plan de Cuidados Preliminar
                                        textarea.form-control(name="planCuidados" rows="2")= evaluacion.Plan_Cuidados_Preliminar || '' 

                        //ANTECEDENTES
                        .col-md-6
                            .card.shadow-sm.mb-3
                                .card-header.bg-warning.text-dark 
                                    | Antecedentes
                                .card-body
                                    h6.text-muted Alergias
                                    div.border.rounded.p-2.mb-3(style="max-height: 150px; overflow-y: auto")
                                        if todasAlergias
                                            each alergia in todasAlergias
                                                //Lógica para ver si está marcado
                                                - const tiene = paciente.alergias && paciente.alergias.some(a => a.id === alergia.id)
                                                .form-check
                                                    input.form-check-input(
                                                        type="checkbox" 
                                                        name="alergias[]" 
                                                        value=alergia.id 
                                                        id=`alergia_${alergia.id}`
                                                        checked=tiene
                                                    )
                                                    label.form-check-label(for=`alergia_${alergia.id}`)= alergia.nombre

                                    h6.text-muted Patologías Previas
                                    div.border.rounded.p-2(style="max-height: 150px; overflow-y: auto;")
                                        if todasPatologias
                                            each opcion in todasPatologias
                                                - const tienePato = paciente.patologias && paciente.patologias.some(p => p.id === opcion.id)
                                                .form-check
                                                    input.form-check-input(
                                                        type="checkbox" 
                                                        name="patologias[]" 
                                                        value=opcion.id 
                                                        id=`pato_${opcion.id}`
                                                        checked=tienePato
                                                    )
                                                    label.form-check-label(for=`pato_${opcion.id}`)= opcion.nombre

                    .card-body.d-flex.justify-content-between.align-items-center
                        a.btn.btn-secondary(href="/enfermeria") 
                            i.fas.fa-arrow-left
                        button.btn.btn-success.btn-lg(type="submit") 
                            | #{evaluacion.ID ? 'Actualizar' : 'Guardar'}


                hr.my-4
                .row.justify-content-center.mb-5
                    .col-md-4.mb-4
                        a(href=`/enfermeria/historia/${internacion.ID}`, class="text-decoration-none h-100")
                            .card.h-100.shadow.text-center.border-0.hover-shadow
                                i.fa-solid.fa-file-alt.fa-4x.text-info.mt-4
                                .card-body
                                    h5.card-title.text-info Historia Clínica
                                    p.card-text.small Ver antecedentes y datos pasados.

                    .col-md-4.mb-4
                        a(href=`/enfermeria/signos/${internacion.ID}`, class="text-decoration-none h-100")
                            .card.h-100.shadow.text-center.border-0
                                i.fa-solid.fa-heart-pulse.fa-4x.text-danger.mt-4
                                .card-body
                                    h5.card-title.text-danger Signos Vitales
                                    p.card-text.small Cargar presión, temperatura y pulso.

                    .col-md-4.mb-4
                        a(href=`/enfermeria/administrar/${internacion.ID}`, class="text-decoration-none h-100")
                            .card.h-100.shadow.text-center.border-0
                                i.fa-solid.fa-syringe.fa-4x.text-success.mt-4
                                .card-body
                                    h5.card-title.text-success Administrar Medicación
                                    p.card-text.small Registrar administración de medicamentos.
doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Recepción Enfermería
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css", rel="stylesheet")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css")
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")
  
  body.bg-light
    //- NAVBAR
    .navbar.navbar-expand-sm.bg-info.navbar-dark.p-3.mb-4
       .container-fluid
           .navbar-brand
               h4.display-6.px-4.text-white Sistema Hospitalario
           .d-flex.ms-auto.align-items-center
               if usuario
                   span.text-white.me-2= usuario.nombre_usuario
               a(href="/logout", title="Cerrar sesión")
                   i.fas.fa-sign-out-alt.text-white

    .container
        //- MENSAJES
        if mensaje
            .alert.alert-warning.text-center #{mensaje}

        //BUSCADOR
        .card.shadow-sm.mb-4
            .card-body
                h5.card-title.text-center Buscar Paciente
                form(action="/enfermeria/buscar" method="GET").d-flex.justify-content-center.gap-2
                    input.form-control.w-50(type="number" name="numeroCama" placeholder="Ingrese número de cama" required)
                    button.btn.btn-primary(type="submit") Buscar

        //DATOS DEL PACIENTE (Solo si se encontró)
        if internacion && paciente
            .card.shadow-sm.mb-5.border-primary
                .card-header.bg-primary.text-white
                    h5.mb-0 Paciente: #{paciente.Nombre} #{paciente.Apellido}
                .card-body
                    .row
                        .col-md-6
                            ul.list-group.list-group-flush
                                li.list-group-item <strong>DNI:</strong> #{paciente.DNI}
                                li.list-group-item <strong>Fecha Nac:</strong> #{paciente.FechaNacimiento.toLocaleDateString()}
                                li.list-group-item <strong>Género:</strong> #{paciente.Genero}
                                 li.list-group-item <strong>Contacto de emergencia:</strong> #{paciente.Contacto_emergencia || 'No registrado'}
                        .col-md-6
                            ul.list-group.list-group-flush
                                li.list-group-item <strong>Obra Social:</strong> #{paciente.obra_social ? paciente.obra_social.nombre : 'Particular'}
                                //- Validamos existencia de cama/habitacion para evitar errores si algo viene null
                                li.list-group-item <strong>Cama:</strong> #{numeroCama || 'N/A'}
                                li.list-group-item <strong>Internación N°:</strong> #{internacion.ID}
                                li.list-group-item <strong>Fecha de ingreso:</strong> #{internacion.FechaIngreso.toLocaleDateString()}

            //BOTONES DE ACCIÓN
            .row.justify-content-center
                .col-md-3.mb-4
                    a(href=`/enfermeria/historia/${internacion.ID}`, class="text-decoration-none h-100")
                        .card.h-100.shadow.text-center.border-0.hover-shadow
                            i.fa-solid.fa-file-alt.fa-4x.text-info.mt-4
                            .card-body
                                h5.card-title.text-info Historia Clínica
                                p.card-text.small Ver antecedentes y datos pasados.

                .col-md-3.mb-4
                    a(href=`/enfermeria/evaluacion/${internacion.ID}`, class="text-decoration-none h-100")
                        .card.h-100.shadow.text-center.border-0
                            i.fa-solid.fa-clipboard-list.fa-4x.text-warning.mt-4
                            .card-body
                                h5.card-title.text-warning Evaluación Inicial
                                p.card-text.small Cargar alergias, motivo de ingreso y triage.

                .col-md-3.mb-4
                    a(href=`/enfermeria/signos/${internacion.ID}`, class="text-decoration-none h-100")
                        .card.h-100.shadow.text-center.border-0
                            i.fa-solid.fa-heart-pulse.fa-4x.text-danger.mt-4
                            .card-body
                                h5.card-title.text-danger Signos Vitales
                                p.card-text.small Cargar presión, temperatura y pulso.

                .col-md-3.mb-4
                    a(href=`/enfermeria/administrar/${internacion.ID}`, class="text-decoration-none h-100")
                        .card.h-100.shadow.text-center.border-0
                            i.fa-solid.fa-syringe.fa-4x.text-success.mt-4
                            .card-body
                                h5.card-title.text-success Administrar Medicación
                                p.card-text.small Registrar administración de medicamentos.
